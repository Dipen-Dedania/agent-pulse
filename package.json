{
  "name": "agent-pulse",
  "version": "1.1.8",
  "description": "",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev:main": "npm run build:main && cross-env NODE_ENV=development electron dist/main/index.js",
    "start": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:main\"",
    "start:info": "cross-env AGENT_PULSE_LOG_LEVEL=info npm start",
    "start:warn": "cross-env AGENT_PULSE_LOG_LEVEL=warn npm start",
    "start:error": "cross-env AGENT_PULSE_LOG_LEVEL=error npm start",
    "start:debug": "cross-env AGENT_PULSE_LOG_LEVEL=debug npm start",
    "test:bridge": "tsx src/main/test-bridge.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pack": "npm run build && electron-builder --dir --config electron-builder.config.cjs",
    "dist": "npm run build && electron-builder --config electron-builder.config.cjs",
    "dist:win": "npm run build && electron-builder --win --publish never --config electron-builder.config.cjs",
    "dist:mac": "npm run build && electron-builder --mac --publish never --config electron-builder.config.cjs",
    "dist:linux": "npm run build && electron-builder --linux --publish never --config electron-builder.config.cjs",
    "dist:all": "npm run build && electron-builder -mwl --publish never --config electron-builder.config.cjs",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dipen-Dedania/agent-pulse.git"
  },
  "keywords": [],
  "author": "",
  "license": "AGPLv3",
  "bugs": {
    "url": "https://github.com/Dipen-Dedania/agent-pulse/issues"
  },
  "homepage": "https://github.com/Dipen-Dedania/agent-pulse#readme",
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "open": "^8.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
